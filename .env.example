# ── Ambiente ──────────────────────────────────────────────────────────────────
# Valores: Development | Staging | Production
ASPNETCORE_ENVIRONMENT=Development

# ── SMTP ──────────────────────────────────────────────────────────────────────
# Servidor SMTP
# Desenvolvimento com Docker: use mailhog / porta 1025 / SSL desativado
# Produção: use o servidor real (ex: smtp.gmail.com / porta 587 / SSL ativado)
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USE_SSL=false
SMTP_USERNAME=
SMTP_PASSWORD=

# ── Remetente ─────────────────────────────────────────────────────────────────
SMTP_SENDER_NAME=Email Sender API
SMTP_SENDER_EMAIL=noreply@emailsenderapi.local

# ── API ───────────────────────────────────────────────────────────────────────
# Porta exposta pelo container da API
API_PORT=8080

# ── MailHog (apenas desenvolvimento) ─────────────────────────────────────────
MAILHOG_SMTP_PORT=1025
MAILHOG_UI_PORT=8025
